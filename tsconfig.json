{
  "include": ["src"],
  "exclude": ["node_modules", "dist"],

  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,

    "types": ["node", "vite/client"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}